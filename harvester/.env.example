# Copie para .env e ajuste. Todos têm padrão sensato — o .env é opcional.

# User-Agent educado (identifique o bot + um contato).
HARVESTER_USER_AGENT=DromosHarvester/0.1 (+https://github.com/seu-usuario/dromos)

# Segundos mínimos entre requisições ao MESMO host (respeita crawl-delay do robots se for maior).
HARVESTER_CRAWL_DELAY=2.0

# Tentativas em falha de rede + backoff (segundos base).
HARVESTER_RETRIES=3
HARVESTER_BACKOFF=1.5

# Diretórios de saída e estado.
HARVESTER_OUT_DIR=./out
HARVESTER_DB_PATH=./out/harvester.sqlite
HARVESTER_HTTP_CACHE=./out/http_cache

# Score mínimo (0..1) para marcar um livro como "infantil" no catálogo.
HARVESTER_KIDS_THRESHOLD=0.55

# Baixar o arquivo inteiro para extrair metadados/capa? (false = tenta só por HTTP range/head).
# PDFs/EPUBs precisam do arquivo para PyMuPDF/ebooklib — deixe true para extração real.
HARVESTER_DOWNLOAD_FILES=true
