{
  "expo": {
    "name": "+leitura",
    "slug": "leitura-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "leituraapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.leiteneto.leitura",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      [
        "expo-media-library",
        {
          "photosPermission": "Salvar o card de leitura na sua galeria.",
          "savePhotosPermission": "Salvar o card de leitura na sua galeria.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-secure-store",
      "expo-audio",
      [
        "expo-notifications",
        {
          "color": "#5EF0A0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supabaseUrl": "https://tffpsfjrqgayrosgmsxy.supabase.co",
      "supabaseAnonKey": "sb_publishable_2nyZxwOzK4usAWVtBQ3qIA_0Y6gGemz",
      "aiProxyFunction": "hyper-task"
    }
  }
}
