.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# IDE (config específica da máquina)
.idea/

# env files — NUNCA versionar (podem conter EXPO_PUBLIC_* e segredos)
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android

# datasets locais (PDFs de treino/tradução) — não versionar binários grandes
docs/datasets-livros-traducao/

